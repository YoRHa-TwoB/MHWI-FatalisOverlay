<Window x:Class="FatalisOverlay.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:FatalisOverlay.Converters"
        Title="战斗日志查看器" Height="640" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E" Foreground="#FFE0E0E0">

    <Window.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <cv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0" Padding="8" Margin="0,0,0,8"
                Background="#2D2D2D" CornerRadius="4" BorderBrush="#555" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Type filters -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="筛选: " VerticalAlignment="Center" Foreground="#AAA" FontSize="12" Margin="0,0,8,0"/>
                    <CheckBox Content="招式" IsChecked="{Binding ShowAction}" Foreground="#4FC3F7" Margin="0,0,8,0"/>
                    <CheckBox Content="伤害" IsChecked="{Binding ShowDamage}" Foreground="#F44336" Margin="0,0,8,0"/>
                    <CheckBox Content="怒" IsChecked="{Binding ShowEnrage}" Foreground="#FF9800"/>
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="重命名" Click="Rename_Click" Width="70" Margin="0,0,4,0"
                            Background="#2D2D2D" Foreground="#FFE0E0E0" BorderBrush="#555"/>
                    <Button Content="删除" Click="Delete_Click" Width="50" Margin="0,0,4,0"
                            Background="#2D2D2D" Foreground="#F44336" BorderBrush="#555"/>
                    <Button Content="刷新" Click="Refresh_Click" Width="50"
                            Background="#2D2D2D" Foreground="#FFE0E0E0" BorderBrush="#555"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Session List -->
            <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="4"
                    BorderBrush="#555" BorderThickness="1">
                <ListBox ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         Background="Transparent" Foreground="#FFE0E0E0"
                         BorderThickness="0"
                         x:Name="SessionListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" BorderBrush="#444" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="#FFF"
                                               Text="{Binding DisplayName, Mode=OneWay, TargetNullValue=''}"/>
                                    <TextBlock Text="{Binding StartTimeText, Mode=OneWay}"
                                               Foreground="#AAA" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StartTimeText, Mode=OneWay}"
                                                   Foreground="#AAA" FontSize="11"/>
                                        <TextBlock Text=" · " Foreground="#555" FontSize="11"/>
                                        <TextBlock Text="{Binding DurationText, Mode=OneWay, StringFormat=时长 {0}}"
                                                   Foreground="#AAA" FontSize="11"/>
                                        <TextBlock Text=" · " Foreground="#555" FontSize="11"/>
                                        <TextBlock Text="{Binding EntryCount, Mode=OneWay, StringFormat={}{0}条}"
                                                   Foreground="#AAA" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#555" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"/>

            <!-- Right: Detail View -->
            <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="4"
                    BorderBrush="#555" BorderThickness="1">
                <Grid>
                    <!-- Empty state: shown when no session selected -->
                    <TextBlock Text="选择左侧对局查看详情" Foreground="#555" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               x:Name="EmptyHint"/>

                    <!-- Entry list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredEntries}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                    <!-- Normal entry (action/damage) -->
                                    <Border Padding="0" Margin="2,1" CornerRadius="3"
                                            Background="#2A2A2A"
                                            Visibility="{Binding IsEnrageEvent, Mode=OneWay, Converter={StaticResource InvBoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2,0,0,2"
                                                    Background="{Binding ColorCode, Mode=OneWay}"/>
                                            <StackPanel Grid.Column="1" Margin="6,4">
                                                <!-- Main line with colored segments -->
                                                <TextBlock FontSize="12" FontWeight="Bold">
                                                    <Run Text="[" Foreground="#666"/>
                                                    <Run Text="{Binding TsDisplay, Mode=OneWay}" Foreground="#888"/>
                                                    <Run Text="] " Foreground="#666"/>
                                                    <Run Text="{Binding ActionTitle, Mode=OneWay}" Foreground="{Binding ColorCode, Mode=OneWay}"/>
                                                    <Run Text="{Binding ActionPost, Mode=OneWay}" Foreground="#CCC"/>
                                                    <Run Text="  " Foreground="Transparent"/>
                                                    <Run Text="{Binding SpiritText, Mode=OneWay}" Foreground="{Binding SpiritColor, Mode=OneWay}" FontWeight="Bold"/>
                                                </TextBlock>
                                                <!-- Detail line: spaced out -->
                                                <TextBlock FontSize="10" Foreground="#AAA" Margin="0,2,0,0">
                                                    <Run Text="{Binding DetailDist, Mode=OneWay}"/>
                                                    <Run Text="{Binding DetailAi, Mode=OneWay}" Foreground="#999"/>
                                                </TextBlock>
                                                <!-- Inline bars -->
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                                        <TextBlock Text="头" Foreground="#888" FontSize="9" Width="16"/>
                                                        <Grid Width="50" Height="5">
                                                            <Border Background="#333" CornerRadius="1"/>
                                                            <Border Background="#2196F3" CornerRadius="1" HorizontalAlignment="Left"
                                                                    Width="{Binding HeadBarW, Mode=OneWay}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding HeadText, Mode=OneWay}" Foreground="#CCC" FontSize="9" Margin="3,0,0,0" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                                        <TextBlock Text="胸" Foreground="#888" FontSize="9" Width="16"/>
                                                        <Grid Width="50" Height="5">
                                                            <Border Background="#333" CornerRadius="1"/>
                                                            <Border Background="#FF9800" CornerRadius="1" HorizontalAlignment="Left"
                                                                    Width="{Binding ChestBarW, Mode=OneWay}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding ChestText, Mode=OneWay}" Foreground="#CCC" FontSize="9" Margin="3,0,0,0" Width="30"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="压" Foreground="#888" FontSize="9" Width="16"/>
                                                        <Grid Width="50" Height="5">
                                                            <Border Background="#333" CornerRadius="1"/>
                                                            <Border Background="#F44336" CornerRadius="1" HorizontalAlignment="Left"
                                                                    Width="{Binding CaBarW, Mode=OneWay}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding CaText, Mode=OneWay}" Foreground="#CCC" FontSize="9" Margin="3,0,0,0" Width="30"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Enrage event: colored bar on dark background -->
                                    <Border Padding="0" Margin="2,1" CornerRadius="3"
                                            Background="#2A2A2A"
                                            Visibility="{Binding IsEnrageEvent, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2,0,0,2"
                                                    Background="{Binding ColorCode, Mode=OneWay}"/>
                                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="Bold"
                                                       Margin="8,4" Foreground="{Binding ColorCode, Mode=OneWay}"
                                                       Text="{Binding Emoji, Mode=OneWay}"/>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
