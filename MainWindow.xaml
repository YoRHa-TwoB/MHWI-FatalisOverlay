<Window x:Class="FatalisOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cv="clr-namespace:FatalisOverlay.Converters"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="Fatalis Overlay"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        Opacity="{Binding Config.Opacity, Mode=OneWay}"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MinWidth="240" MinHeight="60"
        Width="260" Height="Auto" SizeToContent="Height"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <cv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <sys:Double x:Key="Phase1">78</sys:Double>
        <sys:Double x:Key="Phase2">50</sys:Double>
    </Window.Resources>

    <Grid>
        <!-- Full overlay -->
        <Border CornerRadius="8" Padding="12"
                Background="{Binding Config.BackgroundColor, Mode=OneWay}"
                BorderBrush="#44FFFFFF" BorderThickness="1"
                Visibility="{Binding Data.IsFatalis, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <Grid x:Name="FullOverlay">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding Config.Scale, Mode=OneWay}"
                            ScaleY="{Binding Config.Scale, Mode=OneWay}"/>
                </Grid.LayoutTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>  <!-- THK diagnostic -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ Row 0: Quest Timer ═══ -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6"
                            Visibility="{Binding Config.ShowQuestTimer, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="12" VerticalAlignment="Center">
                        <Run Text="任务时间 " Foreground="#AAA"/>
                        <Run Text="{Binding Data.QuestElapsed, Mode=OneWay}" Foreground="#FFF" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock FontSize="12" VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               Visibility="{Binding Data.IsEnraged, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Run Text="⚡ " Foreground="#F44336"/>
                        <Run Text="{Binding Data.EnrageCountdown, Mode=OneWay}" Foreground="#FFF" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Data.SpiritLevelText, Mode=OneWay}" FontSize="12" Margin="4,0,0,0"
                               Foreground="{Binding Data.SpiritLevelColor, Mode=OneWay}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ═══ Row 1: Health ═══ -->
                <Grid Grid.Row="1" Margin="0,0,0,6"
                      Visibility="{Binding Config.ShowHealth, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="黑龙" Foreground="#FFF" FontSize="15" FontWeight="Bold"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="13" VerticalAlignment="Center">
                            <Run Text="{Binding Data.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF"/>
                            <Run Text=" / " Foreground="#888"/>
                            <Run Text="{Binding Data.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF"/>
                            <Run Text="{Binding Data.HealthPercent, Mode=OneWay, StringFormat={}  ({0:F1}%)}" Foreground="#AAA"/>
                        </TextBlock>
                    </StackPanel>
                    <Grid Grid.Row="1" Height="10" x:Name="HealthGauge" Margin="0,2,0,0">
                        <Border Background="#333" CornerRadius="3" BorderBrush="#555" BorderThickness="1"/>
                        <Border Background="{Binding Config.HealthColor, Mode=OneWay}" CornerRadius="3" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.HealthPercent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="HealthGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                        </Border>
                        <!-- Phase markers: 78% and 50% -->
                        <Border Width="2" Background="#CCFF0000" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                Opacity="0.85" CornerRadius="0">
                            <Border.Margin>
                                <MultiBinding Converter="{x:Static cv:PercentToLeftMarginConverter.Instance}">
                                    <Binding Source="{StaticResource Phase1}"/>
                                    <Binding Path="ActualWidth" ElementName="HealthGauge" Mode="OneWay"/>
                                </MultiBinding>
                            </Border.Margin>
                        </Border>
                        <Border Width="2" Background="#CCFF0000" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                Opacity="0.85" CornerRadius="0">
                            <Border.Margin>
                                <MultiBinding Converter="{x:Static cv:PercentToLeftMarginConverter.Instance}">
                                    <Binding Source="{StaticResource Phase2}"/>
                                    <Binding Path="ActualWidth" ElementName="HealthGauge" Mode="OneWay"/>
                                </MultiBinding>
                            </Border.Margin>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══ Row 2: Counterattack + AI + Distance ═══ -->
                <StackPanel Grid.Row="2" Margin="0,0,0,6">
                    <!-- Counterattack -->
                    <Grid Visibility="{Binding Data.HasCounterattack, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid Visibility="{Binding Config.ShowCounterattack, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="下压值" Foreground="#FF9800" FontSize="13" FontWeight="Bold"
                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="{Binding Data.CounterattackDisplay, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF"/>
                            <Run Text=" / " Foreground="#888"/>
                            <Run Text="{Binding Data.CounterattackMaxDisplay, Mode=OneWay}" Foreground="#888"/>
                            </TextBlock>
                            <TextBlock Text=" P3" Foreground="#F44336" FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding Data.CounterattackScaled, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                               Margin="4,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Height="8" x:Name="CounterGauge" Margin="0,2,0,0">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border Background="{Binding Config.CounterattackColor, Mode=OneWay}" CornerRadius="2"
                            HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.CounterattackPercent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="CounterGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- AI + Distance info line -->
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding Config.ShowAiDecision, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Run Text="AI: " Foreground="#888"/>
                            <Run Text="{Binding Data.AiDist, Mode=OneWay, StringFormat={}{0:F0}}" Foreground="#FFF"/>
                            <Run Text="m/" Foreground="#888"/>
                            <Run Text="{Binding Data.AiAngle, Mode=OneWay, StringFormat={}{0:F1}}" Foreground="#FFF"/>
                            <Run Text="°" Foreground="#888"/>
                        </TextBlock>
                        <TextBlock FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Config.ShowDistance, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <Run Text="距: " Foreground="#888"/>
                            <Run Text="{Binding Data.PlayerDistance, Mode=OneWay, StringFormat={}{0:F1}}" Foreground="#FFF"/>
                            <Run Text="m" Foreground="#888"/>
                        </TextBlock>
                        <TextBlock FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Config.ShowPlatform, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="非高台"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Data.IsPlatform}" Value="True">
                                            <Setter Property="Text" Value="对高台"/>
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- THK diagnostic (always visible for debugging) -->
                <TextBlock Grid.Row="3" FontSize="9" Foreground="#FF9800"
                           Text="{Binding Data.ThkDiag, Mode=OneWay}"
                           Margin="0,1,0,4" TextWrapping="Wrap" MaxHeight="26"
                           Visibility="{Binding Config.ShowThkPath, Mode=OneWay, Converter={StaticResource BoolToVis}}"/>

                <!-- ═══ Row 4: Parts ═══ -->
                <StackPanel Grid.Row="4" Margin="0,0,0,4">
                    <!-- Each part line is individually togglable -->
                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartHead, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="头" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartHead.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartHeadGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartHead.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartHeadGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartHead.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartHead.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartHeadGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartHead.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartHead.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            <Run Text="{Binding Data.PartHead.BreakText, Mode=OneWay}" Foreground="#F44336"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartChest, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="胸" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartChest.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartChestGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartChest.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartChestGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartChest.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartChest.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartChestGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartChest.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartChest.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            <Run Text="{Binding Data.PartChest.BreakText, Mode=OneWay}" Foreground="#F44336"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartLArm, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="左手" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartLArm.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartLArmGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartLArm.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartLArmGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartLArm.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartLArm.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartLArmGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartLArm.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartLArm.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartRArm, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="右手" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartRArm.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartRArmGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartRArm.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartRArmGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartRArm.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartRArm.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartRArmGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartRArm.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartRArm.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartLLeg, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="左腿" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartLLeg.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartLLegGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartLLeg.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartLLegGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartLLeg.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartLLeg.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartLLegGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartLLeg.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartLLeg.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartRLeg, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="右腿" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartRLeg.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartRLegGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartRLeg.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartRLegGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartRLeg.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartRLeg.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartRLegGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartRLeg.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartRLeg.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartNeck, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="脖子" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartNeck.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartNeckGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartNeck.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartNeckGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
                            <Border Height="2" VerticalAlignment="Top" HorizontalAlignment="Left" Background="#CCFFFFFF" CornerRadius="1" Visibility="{Binding Data.PartNeck.IsTenderized, Mode=OneWay, Converter={StaticResource BoolToVis}}"><Border.Width><MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}"><Binding Path="Data.PartNeck.TenderizePercent" Mode="OneWay"/><Binding Path="ActualWidth" ElementName="PartNeckGauge" Mode="OneWay"/></MultiBinding></Border.Width></Border>
                        </Grid>
                        <TextBlock Grid.Column="3" Foreground="#FFF" FontSize="10" VerticalAlignment="Center">
                            <Run Text="{Binding Data.PartNeck.MaxHealth, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#AAA"/>
                            <Run Text=" " Foreground="#888"/>
                            <Run Text="{Binding Data.PartNeck.Counter, Mode=OneWay, StringFormat=x{0}}" Foreground="#FF9800"/>
                            
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,1,0,1" Visibility="{Binding Config.ShowPartLWing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="左翼" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Data.PartLWing.Health, Mode=OneWay, StringFormat={}{0:N0}}" Foreground="#FFF" FontSize="10" VerticalAlignment="Center" Margin="4,0"/>
                        <Grid Grid.Column="2" Height="6" Margin="4,0" x:Name="PartLWingGauge">
                            <Border Background="#333" CornerRadius="2" BorderBrush="#555" BorderThickness="1"/>
                            <Border CornerRadius="2" Background="{Binding Config.PartColor, Mode=OneWay}" HorizontalAlignment="Left">
                            <Border.Width>
                            <MultiBinding Converter="{x:Static cv:GaugeWidthConverter.Instance}">
                            <Binding Path="Data.PartLWing.Percent" Mode="OneWay"/>
                            <Binding Path="ActualWidth" ElementName="PartLWingGauge" Mode="OneWay"/>
                            </MultiBinding>
                            </Border.Width>
                            </Border>
                        
