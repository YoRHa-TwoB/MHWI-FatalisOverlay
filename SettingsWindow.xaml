<Window x:Class="FatalisOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fatalis Overlay 设置" Height="640" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FF1E1E1E"
        Foreground="#FFE0E0E0"
        Closing="Window_Closing">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Title -->
            <TextBlock Text="🐉 黑龙 Overlay 设置" FontSize="18" FontWeight="Bold"
                       Margin="0,0,0,12" Foreground="#FF9800"/>

            <!-- Status -->
            <Border Background="#28FFFFFF" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                <TextBlock FontSize="12">
                    <Run Text="状态: " Foreground="#AAA"/>
                    <Run Text="{Binding Data.StatusText, Mode=OneWay}" Foreground="#FFEB3B" FontWeight="Bold"/>
                </TextBlock>
            </Border>

            <!-- Overlay toggle -->
            <CheckBox Content="显示 Overlay 悬浮窗" IsChecked="{Binding OverlayVisible}"
                      FontSize="14" FontWeight="Bold" Margin="0,0,0,10"
                      Foreground="#FFE0E0E0"/>

            <!-- ═══ General Toggles ═══ -->
            <TextBlock Text="▸ 基础项目" FontSize="13" FontWeight="Bold"
                       Foreground="#AAA" Margin="0,8,0,6"/>
            <CheckBox Content="血量 &amp; 血量条" IsChecked="{Binding Config.ShowHealth}"
                      Foreground="#4CAF50" Margin="4,2"/>
            <CheckBox Content="下压值" IsChecked="{Binding Config.ShowCounterattack}"
                      Foreground="#FF9800" Margin="4,2"/>
            <CheckBox Content="AI决策距离/角度" IsChecked="{Binding Config.ShowAiDecision}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="任务计时器" IsChecked="{Binding Config.ShowQuestTimer}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="玩家距离" IsChecked="{Binding Config.ShowDistance}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="高台检测 (对高台/地面)" IsChecked="{Binding Config.ShowPlatform}"
                      Foreground="#FF9800" Margin="4,2"/>

            <!-- ═══ Logging ═══ -->
            <TextBlock Text="▸ 日志" FontSize="13" FontWeight="Bold"
                       Foreground="#AAA" Margin="0,10,0,6"/>
            <CheckBox Content="战斗日志 (输出到 logs/ 文件夹)" IsChecked="{Binding Config.ShowBattleLog}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <Button Content="📋 查看战斗日志" Click="ViewLogs_Click" Width="140" Margin="4,6,4,2"
                    Background="#2D2D2D" Foreground="#FFE0E0E0" BorderBrush="#555"/>

            <!-- ═══ Part Toggles ═══ -->
            <TextBlock Text="▸ 部位破坏 (含硬直计数)" FontSize="13" FontWeight="Bold"
                       Foreground="#2196F3" Margin="0,10,0,6"/>
            <CheckBox Content="头部" IsChecked="{Binding Config.ShowPartHead}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="胸部" IsChecked="{Binding Config.ShowPartChest}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="左手 (左前脚)" IsChecked="{Binding Config.ShowPartLArm}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="右手 (右前脚)" IsChecked="{Binding Config.ShowPartRArm}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="左腿 (左后脚)" IsChecked="{Binding Config.ShowPartLLeg}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="右腿 (右后脚)" IsChecked="{Binding Config.ShowPartRLeg}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="脖子" IsChecked="{Binding Config.ShowPartNeck}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="左翼" IsChecked="{Binding Config.ShowPartLWing}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>
            <CheckBox Content="右翼" IsChecked="{Binding Config.ShowPartRWing}"
                      Foreground="#FFE0E0E0" Margin="4,2"/>

            <!-- ═══ Ailment Toggles ═══ -->
            <TextBlock Text="▸ 异常状态" FontSize="13" FontWeight="Bold"
                       Foreground="#FF9800" Margin="0,10,0,6"/>
            <CheckBox Content="毒" IsChecked="{Binding Config.ShowAilmentPoison}"
                      Foreground="#9C27B0" Margin="4,2"/>
            <CheckBox Content="麻痹" IsChecked="{Binding Config.ShowAilmentPara}"
                      Foreground="#FFEB3B" Margin="4,2"/>
            <CheckBox Content="睡眠" IsChecked="{Binding Config.ShowAilmentSleep}"
                      Foreground="#64B5F6" Margin="4,2"/>
            <CheckBox Content="爆破" IsChecked="{Binding Config.ShowAilmentBlast}"
                      Foreground="#F44336" Margin="4,2"/>
            <CheckBox Content="昏厥" IsChecked="{Binding Config.ShowAilmentStun}"
                      Foreground="#FFC107" Margin="4,2"/>
            <CheckBox Content="减气" IsChecked="{Binding Config.ShowAilmentExhaust}"
                      Foreground="#81C784" Margin="4,2"/>
            <CheckBox Content="骑乘" IsChecked="{Binding Config.ShowAilmentMount}"
                      Foreground="#4FC3F7" Margin="4,2"/>
            <CheckBox Content="发怒" IsChecked="{Binding Config.ShowAilmentEnrage}"
                      Foreground="#EF5350" Margin="4,2"/>

            <!-- ═══ Appearance ═══ -->
            <TextBlock Text="▸ 外观" FontSize="13" FontWeight="Bold"
                       Foreground="#AAA" Margin="0,12,0,6"/>

            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="缩放" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="0.5" Maximum="3.0" Value="{Binding Config.Scale}"
                        TickFrequency="0.1" IsSnapToTickEnabled="True"/>
            </Grid>
            <TextBlock Text="{Binding Config.Scale, StringFormat={}当前: {0:F1}x}"
                       Foreground="#888" FontSize="10" Margin="84,0,0,2"/>

            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="刷新间隔" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" Minimum="10" Maximum="200" Value="{Binding Config.PollingRateMs}"
                        TickFrequency="10" IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" Text="{Binding Config.PollingRateMs, StringFormat={}{0:F0}ms}"
                           Foreground="#888" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Colors -->
            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="血量颜色" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Config.HealthColor, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF" Background="#2D2D2D" BorderBrush="#555"
                         FontFamily="Consolas" FontSize="12"/>
            </Grid>
            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="下压值颜色" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Config.CounterattackColor, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF" Background="#2D2D2D" BorderBrush="#555"
                         FontFamily="Consolas" FontSize="12"/>
            </Grid>
            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="部位颜色" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Config.PartColor, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF" Background="#2D2D2D" BorderBrush="#555"
                         FontFamily="Consolas" FontSize="12"/>
            </Grid>
            <Grid Margin="4,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="背景颜色" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Config.BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#FFF" Background="#2D2D2D" BorderBrush="#555"
                         FontFamily="Consolas" FontSize="12"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="保存配置" Click="Save_Click" Width="100" Margin="0,0,8,0"
                        Background="#2D2D2D" Foreground="#FFE0E0E0" BorderBrush="#555"/>
                <Button Content="打开文件夹" Click="OpenFolder_Click"
                        Background="#2D2D2D" Foreground="#FFE0E0E0" BorderBrush="#555"/>
            </StackPanel>

            <TextBlock Height="8"/>
            <TextBlock Text="Made by YoRHaTwoB, v1.0"
                       Foreground="#FF9800" FontSize="10" HorizontalAlignment="Center" Margin="0,4"/>
        </StackPanel>
    </ScrollViewer>
</Window>
